# Module build dirs (the root /build above is anchored; feature/lib modules need this too)
build/

# Model weights are never committed here: this app is bring-your-own-model (docs/models.md).
# Drop graphs matching the contract at data/src/main/assets/{sem,det}.tflite to run locally; they
# stay out of every commit. A downstream distribution that does ship weights tracks them with
# `git add -f`, which overrides this rule for good.
data/src/main/assets/*.tflite

# Qualcomm NPU runtime: large, re-fetchable vendor .so + build output are NOT tracked.
# Reconstruct locally per docs/npu-litert-qnn.md (download the zip, extract to repo root,
# run the fetch script, set the modules' minSdk = base app minSdk).
/litert_npu_runtime_libraries/
/litert_npu_runtime_libraries_jit/

# NPU diagnostics / on-device verification scratch
*.apks
/verify*.txt
/litert_npu_diag*.tar
/diag_extract*/

# Store listing assets (icon / feature graphic exports); regenerate as needed
/store/
